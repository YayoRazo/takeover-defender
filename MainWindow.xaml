<Window x:Class="TakeoverDefender.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Takeover Defender"
        Width="600" Height="580"
        MinWidth="520" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e"
        Foreground="#cdd6f4"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="2"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#cdd6f4"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,12,0,20">
            <TextBlock Text="Takeover Defender"
                       FontSize="28" FontWeight="Bold"
                       Foreground="#cba6f7"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Take full control of Windows Defender"
                       FontSize="13"
                       Foreground="#a6adc8"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="#313244"
                CornerRadius="10"
                Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0"
                         x:Name="StatusDot"
                         Width="16" Height="16"
                         Fill="#a6adc8"
                         VerticalAlignment="Center"
                         Margin="0,0,16,0"
                         AutomationProperties.Name="Defender status indicator"/>

                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="StatusTitle"
                               Text="Checking status..."
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="#cdd6f4"/>
                    <TextBlock x:Name="StatusDetail"
                               Text=""
                               FontSize="12"
                               Foreground="#a6adc8"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <Button x:Name="BtnTakeOver"
                    Content="TAKE OVER - Disable All"
                    Style="{StaticResource ActionButton}"
                    Background="#d20f17"
                    Click="BtnTakeOver_Click"/>

            <Button x:Name="BtnRestore"
                    Content="RESTORE - Enable All"
                    Style="{StaticResource ActionButton}"
                    Background="#40a02b"
                    Foreground="#1e1e2e"
                    Click="BtnRestore_Click"/>

            <ProgressBar x:Name="Progress"
                         Height="3"
                         Margin="0,12,0,0"
                         IsIndeterminate="True"
                         Background="#313244"
                         Foreground="#cba6f7"
                         Visibility="Collapsed"/>
        </StackPanel>

        <TextBlock Grid.Row="3"
                   x:Name="TxtWarning"
                   Text=""
                   FontSize="12"
                   Foreground="#f38ba8"
                   TextWrapping="Wrap"
                   Margin="0,12,0,0"
                   Visibility="Collapsed"/>

        <Border Grid.Row="4"
                Background="#181825"
                CornerRadius="8"
                Margin="0,12,0,0"
                Padding="4">
            <TextBox x:Name="TxtLog"
                     FontFamily="Consolas"
                     FontSize="12"
                     Foreground="#a6adc8"
                     Background="Transparent"
                     BorderThickness="0"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     Padding="10"
                     CaretBrush="#a6adc8"
                     Text="Ready. Press TAKE OVER to disable Windows Defender and Antimalware."/>
        </Border>

        <TextBlock Grid.Row="5"
                   Text="Requires Administrator privileges. Use responsibly."
                   FontSize="11"
                   Foreground="#585b70"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0"/>
    </Grid>
</Window>
